# Dream Log/.env (测试、预发布、生产环境配置)

# ===============================================
# 1. 服务初始化变量 (给 MySQL/RabbitMQ 镜像自己用)
# ===============================================

# --- MySQL ---
# 这个是 MySQL 容器用来设置 root 用户的密码的
MYSQL_ROOT_PASSWORD=your_strong_mysql_root_password
# 这个是 MySQL 容器初始化时自动创建的数据库名
MYSQL_DATABASE=dream
# 这个是 MySQL 容器初始化时自动创建的普通用户名
MYSQL_USER=dream_user
# 这个是 MySQL 容器初始化时自动创建的普通用户密码
MYSQL_PASSWORD=your_strong_mysql_user_password


# --- RabbitMQ ---
# RabbitMQ 管理后台的登录用户名
RABBITMQ_DEFAULT_USER=dream_admin
# RabbitMQ 管理后台的登录密码
RABBITMQ_DEFAULT_PASS=your_strong_rabbitmq_password
RABBITMQ_DEFAULT_VHOST=/

# --- Redis ---
# Redis 服务的访问密码
REDIS_PASSWORD=your_strong_redis_password


# ===============================================
# 2. Django 应用配置变量 (给 backend/worker 容器用)
# ===============================================

# --- Django 核心 ---
DJANGO_SECRET_KEY="your-super-secret-and-long-django-key"
DEBUG=False
ALLOWED_HOSTS=your_domain.com,www.your_domain.com,120.216.67.22

# --- 数据库连接 (注意 HOST 指向服务名) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=${MYSQL_DATABASE}  # 使用上面定义的值
DB_USER=${MYSQL_USER}      # 使用上面定义的值
DB_PASSWORD=${MYSQL_PASSWORD} # 使用上面定义的值

# --- Redis 连接 (注意 HOST 指向服务名) ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_DB=0
# 注意，这里的 REDIS_PASSWORD 必须和上面服务初始化的密码一致
# Django 应用也需要它来构建连接字符串

# --- RabbitMQ/Celery 连接 (注意 HOST 指向服务名) ---
RABBITMQ_HOST=broker
RABBITMQ_PORT=5672
# 注意，这里的用户名/密码必须和上面服务初始化的用户名/密码一致

# --- JWT 配置 ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- 阿里云配置 (生产环境的真实 Key) ---
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 阿里云OSS配置
ALIYUN_OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
ALIYUN_STS_ROLE_OSS_ARN=acs:ram::1945809635507741:role/oss-upload-role

# 阿里云短信配置
ALIYUN_STS_ROLE_SMS_ARN=acs:ram::1945809635507741:role/smsrole
ALIYUN_SMS_SIGN1=sass平台
ALIYUN_SMS_SIGN2=BugTracer平台
ALIYUN_SMS_TEMPLATE_REGISTER=SMS_474810651
ALIYUN_SMS_TEMPLATE_LOGIN=SMS_474835623
ALIYUN_SMS_TEMPLATE_RESETPASSWORD=SMS_474835...624