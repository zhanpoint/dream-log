# Dream Log API - 环境变量实际配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 应用配置
# ============================================
APP_NAME=Dream Log API
APP_ENV=development
DEBUG=true
SECRET_KEY=

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=dreamlog-backend
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/dreamlog-backend

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=
REDIS_URL=redis://:password@cache:6379/0

# ============================================
# JWT 配置
# ============================================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# SMTP 邮件配置
# ============================================
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# ============================================
# Google OAuth 配置
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ============================================
# AI 服务配置
# ============================================
OPENROUTER_API_KEY=

# ============================================
# AI 模型配置
# ============================================
AI_MODEL_TEXT_ANALYSIS=google/gemini-3.1-flash-lite-preview
AI_MODEL_TITLE_GENERATION=google/gemini-3.1-flash-lite-preview
AI_MODEL_INSIGHT_GENERATION=google/gemini-3.1-flash-lite-preview
AI_MODEL_IMAGE_GENERATION=google/gemini-3.1-flash-image-preview
AI_MODEL_EMBEDDING=openai/text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1024

# ============================================
# 语音转录 Provider 开关
# ============================================
VOICE_TRANSCRIBE_PROVIDER=xfyun

# ============================================
# Dify 工作流（梦境符号批量生成脚本 scripts/symbols/batch_generate.py）
# ============================================
DIFY_API_KEY=
DIFY_API_URL=https://api.dify.ai/v1/workflows/run

# ============================================
# 讯飞星火配置（实时语音转写大模型）
# ============================================
XFYUN_APP_ID=
XFYUN_ACCESS_KEY_ID=
XFYUN_ACCESS_KEY_SECRET=

# ============================================
# Google Cloud 配置（语音实时转录）
# ============================================
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_CREDENTIALS_JSON={}

# ============================================
# 阿里云 OSS 配置
# ============================================
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
ALIYUN_OSS_ROLE_ARN=
ALIYUN_OSS_PUBLIC_BUCKET=
ALIYUN_OSS_PRIVATE_BUCKET=

# ============================================
# 前端配置
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# 代理配置（AI 专用，生产环境建议设置）
# ============================================
AI_PROXY_URL=http://host.docker.internal:7897
