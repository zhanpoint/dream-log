# Dream Log/.env.example
# ===============================================
# 1. 服务初始化变量 (给 MySQL/Redis/RabbitMQ 镜像自己用)
# ===============================================

# --- MySQL ---
# MYSQL_ROOT_PASSWORD: MySQL root 用户的密码 (必须提供)
MYSQL_ROOT_PASSWORD=
# MYSQL_DATABASE: MySQL 初始化时自动创建的数据库名
MYSQL_DATABASE=dream
# MYSQL_USER: 初始化时创建的普通用户名 (建议 Django 用普通用户连接)
MYSQL_USER=dream_user
# MYSQL_PASSWORD: 普通用户密码
MYSQL_PASSWORD=

# --- RabbitMQ ---
# RabbitMQ 管理后台登录用户名 (必须提供)
RABBITMQ_DEFAULT_USER=
# RabbitMQ 管理后台登录密码 (必须提供)
RABBITMQ_DEFAULT_PASS=
RABBITMQ_DEFAULT_VHOST=/

# --- Redis ---
# Redis 服务的访问密码
REDIS_PASSWORD=

# --- PostgreSQL ---
# PostgreSQL 容器初始化环境变量
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=langgraph_db
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# ===============================================
# 2. Django 应用配置变量 (给 backend/worker 容器用)
# ===============================================

# --- Django 核心 ---
DJANGO_SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=*

# --- 数据库连接 ---
DB_HOST=db
DB_PORT=3306
DB_NAME=${MYSQL_DATABASE}
DB_USER=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}

# --- Redis 连接 ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_DB=0

# --- RabbitMQ/Celery 连接 ---
RABBITMQ_HOST=broker
RABBITMQ_PORT=5672

# ===============================================
# 3. 阿里云配置
# ===============================================

# RAM 用户 AccessKey
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# 阿里云 OSS 配置
ALIYUN_OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
ALIYUN_STS_ROLE_OSS_ARN=
ALIYUN_OSS_SHARED_BUCKET_NAME=

# 阿里云短信配置
SMS_SERVICE_ENABLED=False
ALIYUN_STS_ROLE_SMS_ARN=
ALIYUN_SMS_SIGN=
ALIYUN_SMS_TEMPLATE_REGISTER=
ALIYUN_SMS_TEMPLATE_LOGIN=
ALIYUN_SMS_TEMPLATE_RESETPASSWORD=

# ===============================================
# 4. JWT 设置
# ===============================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ===============================================
# 5. 邮件推送配置
# ===============================================
EMAIL_SERVICE_ENABLED=True
EMAIL_HOST=smtpdm.aliyun.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# ===============================================
# 6. AI 服务配置
# ===============================================
OPENROUTER_API_KEY=
OPENROUTER_MODELS=google/gemini-2.5-flash-lite,google/gemini-2.5-flash-lite-preview-06-17,deepseek/deepseek-chat-v3-0324:free

# TAVILY
TAVILY_API_KEY=
# FIRECRAWL
FIRECRAWL_API_KEY=
# Google Gemini
GOOGLE_API_KEY=
# ChromaDB Cloud
CHROMA_CLOUD_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=dream_knowledge_base
CHROMA_COLLECTION_NAME=dream_knowledge_base
# Voyage
VOYAGE_API_KEY=
# Embedding 模型
EMBEDDING_MODEL=voyage-3.5-lite

# 是否开启 RAG
RAG_ENABLED=False

# LangGraph 专用 PostgreSQL 数据库配置 (与 postgres 容器保持一致)
LANGGRAPH_DB_HOST=postgres
LANGGRAPH_DB_PORT=5432
LANGGRAPH_DB_NAME=${POSTGRES_DB}
LANGGRAPH_DB_USER=${POSTGRES_USER}
LANGGRAPH_DB_PASSWORD=${POSTGRES_PASSWORD}

# ===============================================
# 7. 代理配置
# ===============================================
PROXY_URL=
