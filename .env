# Dream Log/.env (测试、预发布、生产环境配置)

# ===============================================
# 1. 服务初始化变量 (给 MySQL/redis/RabbitMQ 镜像自己用)
# ===============================================

# --- MySQL ---
# 这个是 MySQL 容器用来设置 root 用户的密码的(MYSQL_ROOT_PASSWORD必须提供。 用于设置MySQL root 用户的密码。)
MYSQL_ROOT_PASSWORD=333444
# 这个是 MySQL 容器初始化时自动创建的数据库名
MYSQL_DATABASE=dream
# 这个是 MySQL 容器初始化时自动创建的普通用户名(如果你需要一个非 root 的普通用户用于 Django 连接数据库)
MYSQL_USER=dream_user
# 这个是 MySQL 容器初始化时自动创建的普通用户密码(如果你需要一个非 root 的普通用户用于 Django 连接数据库)
MYSQL_PASSWORD=333444


# --- RabbitMQ ---
# RabbitMQ 管理后台的登录用户名(必须提供)
RABBITMQ_DEFAULT_USER=dream_admin
# RabbitMQ 管理后台的登录密码(必须提供)
RABBITMQ_DEFAULT_PASS=333444lL
RABBITMQ_DEFAULT_VHOST=/

# --- Redis ---
# Redis 服务的访问密码
REDIS_PASSWORD=333444


# ===============================================
# 2. Django 应用配置变量 (给 backend/worker 容器用)
# ===============================================

# --- Django 核心 ---
DJANGO_SECRET_KEY='django-insecure-fe1*#ihdw0+-9!-lt1-1mzj4rnby9=xia)*1!kmxi!8y=i+1pz'
DEBUG=False
ALLOWED_HOSTS=*

# --- 数据库连接 (注意 HOST 指向docker-compose服务名) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=${MYSQL_DATABASE}  # 使用上面定义的值
DB_USER=root     # 使用上面定义的值(使用root用户不使用普通用户)
DB_PASSWORD=${MYSQL_ROOT_PASSWORD} # 使用上面定义的值(使用root用户密码)

# --- Redis 连接 (注意 HOST 指向服务名) ---
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_DB=0

# --- RabbitMQ/Celery 连接 (注意 HOST 指向服务名) ---
RABBITMQ_HOST=broker
RABBITMQ_PORT=5672

