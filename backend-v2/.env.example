# ============================================
# Dream Log API - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值

# ============================================
# 应用配置
# ============================================
APP_NAME=Dream Log API
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://dreamlog:password@localhost:5432/dreamlog

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT 配置
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# SMTP 邮件配置
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# ============================================
# Google OAuth 配置
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ============================================
# AI 服务配置
# ============================================
# OpenRouter (统一 AI 入口)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ============================================
# AI 模型配置
# ============================================
# 两阶段分析：阶段1 基础分析 / 阶段2 深度洞察
# 阶段1 基础分析模型 (低温精确)
AI_MODEL_TEXT_ANALYSIS=openai/gpt-5.2

# 标题生成模型 (高温人性化)
AI_MODEL_TITLE_GENERATION=google/gemini-3-flash-preview

# 阶段2 深度洞察模型 (中高温共情)
AI_MODEL_INSIGHT_GENERATION=openai/gpt-5.2

# 梦境图像生成模型 (通过 OpenRouter 调用，需支持图像输出)
AI_MODEL_IMAGE_GENERATION=google/gemini-2.5-flash-image

# 文本嵌入模型
AI_MODEL_EMBEDDING=openai/text-embedding-3-large

# 嵌入维度
AI_EMBEDDING_DIMENSIONS=1024

# ============================================
# 精选梦境自动筛选配置
# ============================================
# AUTO 模式入选阈值（0-100）
FEATURED_AUTO_THRESHOLD=70
# 最低可读内容字数阈值
FEATURED_MIN_CONTENT_LENGTH=50
# 自动重算窗口（最近 N 天 AUTO 梦境）
FEATURED_RECALC_WINDOW_DAYS=14
# 每次重算最多处理条数（轻量任务）
FEATURED_RECALC_BATCH_SIZE=500
# 是否开启每小时重算任务
FEATURED_RECALC_HOURLY_ENABLED=true
# 是否开启每日兜底重算任务
FEATURED_RECALC_DAILY_ENABLED=true

# tiktoken 缓存目录（可选）。未设置时默认使用 backend-v2/.tiktoken_cache。
# 若出现 openaipublic.blob.core.windows.net / cl100k_base.tiktoken 的 SSL 或连接错误，
# 可：1) 使用 VPN 运行一次让缓存自动下载；2) 或手动下载后放到缓存目录：
#    https://openaipublic.blob.core.windows.net/encodings/cl100k_base.tiktoken
#    保存为 <TIKTOKEN_CACHE_DIR>/9b5ad71b2ce5302211f9c61530b329a4922fc6a4
# TIKTOKEN_CACHE_DIR=.tiktoken_cache

# ============================================
# Dify 工作流（梦境符号批量生成脚本 scripts/symbols/batch_generate.py）
# ============================================
# 从 Dify 控制台 → API 访问 获取
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx
# 云端默认如下；自建 Dify 改为实际地址，如 https://your-dify.com/v1/workflows/run
DIFY_API_URL=https://api.dify.ai/v1/workflows/run

# ============================================
# 语音转录 Provider 开关
# ============================================
# 可选值: "google" (Google Cloud Speech-to-Text) | "xfyun" (讯飞星火实时转写)
VOICE_TRANSCRIBE_PROVIDER=xfyun

# ============================================
# 讯飞星火配置（实时语音转写大模型）
# ============================================
# 从 https://console.xfyun.cn/services/rta_new 获取
XFYUN_APP_ID=your-xfyun-app-id
XFYUN_ACCESS_KEY_ID=your-xfyun-access-key-id
XFYUN_ACCESS_KEY_SECRET=your-xfyun-access-key-secret

# ============================================
# Google Cloud 配置（语音实时转录）
# ============================================
# 项目 ID（必须启用 Speech-to-Text API）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_CREDENTIALS_JSON={}

# ============================================
# 阿里云 OSS 配置
# ============================================
# 访问凭证
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
ALIYUN_OSS_ROLE_ARN=acs:ram::xxx:role/oss-role

# 公开 Bucket：存放头像、公开图片等（设置为公共读）
ALIYUN_OSS_PUBLIC_BUCKET=dreamlog-public

# 私密 Bucket：存放用户文档、私密文件等（设置为私有）
ALIYUN_OSS_PRIVATE_BUCKET=dreamlog-private
