# ============================================
# Dream Log API - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值

# ============================================
# 应用配置
# ============================================
APP_NAME=Dream Log API
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://dreamlog:password@localhost:5432/dreamlog

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT 配置
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# SMTP 邮件配置
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# ============================================
# Google OAuth 配置
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ============================================
# AI 服务配置
# ============================================
# OpenRouter (统一 AI 入口)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# 可选: 直接调用 OpenAI/Google
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ============================================
# 阿里云 OSS 配置
# ============================================
# 访问凭证
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_ENDPOINT=oss-cn-wuhan-lr.aliyuncs.com
ALIYUN_OSS_ROLE_ARN=acs:ram::xxx:role/oss-role

# 公开 Bucket：存放头像、公开图片等（设置为公共读）
ALIYUN_OSS_PUBLIC_BUCKET=dreamlog-public

# 私密 Bucket：存放用户文档、私密文件等（设置为私有）
ALIYUN_OSS_PRIVATE_BUCKET=dreamlog-private
