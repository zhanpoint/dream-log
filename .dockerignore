# Exclude local environments and secrets
.env
.env.*
!*.env.example
!**/*.env.example

# Frontend Next.js build output
frontend/.next
frontend/.next/**

# Node artifacts
frontend/node_modules
frontend/dist
frontend/dist-ssr

# Python artifacts
__pycache__
*.py[cod]
*$py.class

# VCS
.git
.gitignore

# Editor/OS files
.vscode
.idea
.DS_Store
Thumbs.db
